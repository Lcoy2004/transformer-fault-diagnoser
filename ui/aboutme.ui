/* ================================================
   关于对话框 - 现代化简约风格
   设计理念：专业、简洁、清晰
   ================================================ */

QDialog#Dialog_aboutme {
    background-color: #f0f4f8;
    border: 1px solid #dde2e8;
    border-radius: 12px;
}

/* 文本编辑框 - 主内容区 */
QTextBrowser#textEdit {
    background-color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 20px 24px;
    selection-background-color: #bbdefb;
    color: #334155;
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.7;
}

/* 标题样式 - 使用 HTML */
QTextBrowser#textEdit strong {
    color: #1e3a5f;
    font-size: 15px;
}

/* 链接样式 */
QTextBrowser#textEdit a {
    color: #1e88e5;
    text-decoration: none;
}

QTextBrowser#textEdit a:hover {
    color: #1976d2;
    text-decoration: underline;
}

</string>
