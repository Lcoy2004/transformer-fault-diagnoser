<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>chart_container</class>
 <widget class="QWidget" name="chart_container">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>800</width>
    <height>650</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>650</width>
    <height>650</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>原始数据显示图</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ================================================
   图表界面 - 现代化工业风格
   设计理念：专业、数据可视化优先、清晰层次
   ================================================ */

/* ========== 全局容器 ========== */
QWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 13px;
}

/* ========== 选择器区域 ========== */
QLabel {
    color: #475569;
    background-color: transparent;
    padding: 2px 0px;
    font-weight: 500;
}

QComboBox {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 7px 12px;
    background-color: #ffffff;
    min-height: 20px;
    color: #334155;
    font-size: 12px;
}

QComboBox:hover {
    border-color: #94a3b8;
}

QComboBox:focus {
    border-color: #3b82f6;
    outline: none;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 24px;
    border-left: 1px solid #e2e8f0;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    background-color: #f8fafc;
}

QComboBox::drop-down:hover {
    background-color: #f1f5f9;
}

QComboBox::down-arrow {
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #64748b;
}

QComboBox QAbstractItemView {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background-color: #ffffff;
    selection-background-color: #e0e7ff;
    outline: none;
    padding: 4px 0px;
}

QComboBox QAbstractItemView::item {
    padding: 8px 14px;
    min-height: 18px;
    color: #334155;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #f1f5f9;
}

/* ========== 信息标签 ========== */
QLabel#info_label {
    color: #64748b;
    font-size: 12px;
    padding: 6px 10px;
    background-color: #f8fafc;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
}

/* ========== 图表区域 ========== */
QChartView {
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background-color: #ffffff;
}

/* ========== 统计面板分组框 ========== */
QGroupBox {
    font-weight: bold;
    color: #334155;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 8px;
    color: #3b82f6;
}

QGroupBox#stats_widget {
    color: #3b82f6;
}

/* ========== 统计表格 ========== */
QTableWidget {
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background-color: #ffffff;
    gridline-color: #f1f5f9;
    selection-background-color: #e0e7ff;
    font-size: 12px;
}

QTableWidget::item {
    padding: 8px;
    border-bottom: 1px solid #f8fafc;
    color: #475569;
}

QTableWidget::item:selected {
    background-color: #e0e7ff;
    color: #3730a3;
}

QHeaderView::section {
    background-color: #f8fafc;
    padding: 10px 8px;
    border: none;
    border-bottom: 2px solid #e2e8f0;
    border-right: 1px solid #f1f5f9;
    font-weight: 600;
    color: #475569;
    font-size: 12px;
}

QHeaderView::section:hover {
    background-color: #f1f5f9;
}

QTableWidget QTableCornerButton::section {
    background-color: #f8fafc;
    border: none;
    border-bottom: 2px solid #e2e8f0;
}

/* ========== 故障分布标签 ========== */
QLabel#fault_dist_label {
    color: #475569;
    font-size: 11px;
    padding: 8px 10px;
    background-color: #f8fafc;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    line-height: 1.6;
}

/* ========== 图例 ========== */
QLabel#legend_item {
    color: #475569;
    font-size: 11px;
    padding: 4px 10px;
    background-color: transparent;
}

/* ========== 滚动条 ========== */
QScrollBar:vertical {
    background-color: #f8fafc;
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background-color: #cbd5e1;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #94a3b8;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #f8fafc;
    height: 8px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal {
    background-color: #cbd5e1;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #94a3b8;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}
</string>
  </property>
 </widget>
 <resources/>
 <connections/>
</ui>
