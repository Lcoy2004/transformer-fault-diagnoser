  <property name="styleSheet">
   <string notr="true">/* ========== 全局背景 ========== */
QMainWindow, QDialog {
    background-color: #f5f7fa;   /* 柔和灰蓝 */
}

/* ========== 菜单栏 ========== */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e0e4e8;
    padding: 4px 8px;
}
QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 6px;
    color: #2c3e50;
}
QMenuBar::item:selected {
    background-color: #eaeef2;
    color: #1a73e8;
}
QMenuBar::item:pressed {
    background-color: #d0d7de;
}

QMenu {
    background-color: #ffffff;
    border: 1px solid #d0d7de;
    border-radius: 8px;
    padding: 4px 0px;
}
QMenu::item {
    padding: 8px 24px;
    border-radius: 4px;
    color: #2c3e50;
}
QMenu::item:selected {
    background-color: #e1eaf0;
    color: #1a73e8;
}
QMenu::separator {
    height: 1px;
    background-color: #d0d7de;
    margin: 4px 8px;
}

/* ========== 状态栏 ========== */
QStatusBar {
    background-color: #eaeef2;
    color: #4a5a6e;
    border-top: 1px solid #d0d7de;
    padding: 4px 8px;
}

/* ========== 按钮 ========== */
QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    min-width: 80px;
    font-weight: 500;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
    background-color: #1c6ea4;
}
QPushButton:flat {
    background-color: transparent;
    color: #2c3e50;
}
QPushButton:flat:hover {
    background-color: #eaeef2;
}

/* 特定按钮样式（可选，根据需要调整） */
QPushButton#btn_pd {
    background-color: #e67e22;
}
QPushButton#btn_pd:hover {
    background-color: #d35400;
}
QPushButton#btn_rf {
    background-color: #27ae60;
}
QPushButton#btn_rf:hover {
    background-color: #229954;
}

/* ========== 组合框 ========== */
QComboBox {
    border: 1px solid #d0d7de;
    border-radius: 6px;
    padding: 6px 12px;
    background-color: #ffffff;
    min-height: 20px;
}
QComboBox:hover {
    border-color: #8a9aa8;
    background-color: #fafbfc;
}
QComboBox:focus {
    border-color: #3498db;
    outline: none;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 24px;
    border-left: 1px solid #d0d7de;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    background-color: #f6f8fa;
}
QComboBox::drop-down:hover {
    background-color: #eaeef2;
}
QComboBox QAbstractItemView {
    border: 1px solid #d0d7de;
    border-radius: 6px;
    background-color: #ffffff;
    selection-background-color: #e1eaf0;
    outline: none;
    padding: 4px 0px;
}
QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    min-height: 20px;
}
QComboBox QAbstractItemView::item:hover {
    background-color: #f1f5f9;
}

/* ========== 表格 ========== */
QTableWidget {
    border: 1px solid #d0d7de;
    border-radius: 6px;
    background-color: #ffffff;
    gridline-color: #eaeef2;
}
QTableWidget::item {
    padding: 6px;
    border-bottom: 1px solid #eaeef2;
}
QTableWidget::item:selected {
    background-color: #e1eaf0;
    color: #1a73e8;
}
QHeaderView::section {
    background-color: #f6f8fa;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #d0d7de;
    font-weight: 600;
    color: #2c3e50;
}
QHeaderView::section:horizontal {
    border-right: 1px solid #d0d7de;
}
QHeaderView::section:vertical {
    border-right: 1px solid #d0d7de;
}

/* ========== 文本编辑框 ========== */
QTextEdit {
    border: 1px solid #d0d7de;
    border-radius: 6px;
    padding: 8px;
    background-color: #ffffff;
    selection-background-color: #e1eaf0;
}
QTextEdit:hover {
    border-color: #8a9aa8;
    background-color: #fafbfc;
}
QTextEdit:focus {
    border-color: #3498db;
    outline: none;
}

/* ========== 标签 ========== */
QLabel {
    color: #2c3e50;
    background-color: transparent;
    padding: 2px 4px;
}
QLabel#notification_label {
    font-weight: 600;
    color: #1a73e8;
}
QLabel#showtime_label {
    font-weight: 600;
    color: #e67e22;
}

/* ========== 进度条 ========== */
QProgressBar {
    border: 1px solid #d0d7de;
    border-radius: 4px;
    background-color: #ffffff;
    text-align: center;
    color: #2c3e50;
}
QProgressBar::chunk {
    background-color: #3498db;
    border-radius: 3px;
}

/* ========== 布局容器（可选，一般不用） ========== */
QWidget#centralwidget {
    background-color: transparent;  /* 继承主窗口背景 */
}</string>
