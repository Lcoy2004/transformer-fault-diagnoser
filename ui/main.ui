  <property name="styleSheet">
   <string notr="true">
/* ================================================
   现代化工业软件界面样式表
   设计理念：简洁、专业、高效、扁平化
   主色调：深蓝灰 (#1E293B)
   强调色：科技蓝 (#3B82F6)
   辅助色：中灰 (#64748B)、浅灰 (#F1F5F9)
   ================================================ */

/* ========== 全局背景 ========== */
QMainWindow {
    background-color: #F8FAFC;
}

QWidget {
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 13px;
    color: #1E293B;
}

/* ========== 菜单栏 ========== */
QMenuBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
    padding: 6px 12px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 8px 16px;
    border-radius: 6px;
    color: #334155;
}

QMenuBar::item:selected {
    background-color: #EFF6FF;
    color: #3B82F6;
}

QMenuBar::item:pressed {
    background-color: #DBEAFE;
}

QMenu {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    padding: 8px 0px;
}

QMenu::item {
    padding: 10px 32px 10px 16px;
    border-radius: 4px;
    color: #334155;
}

QMenu::item:selected {
    background-color: #EFF6FF;
    color: #3B82F6;
}

QMenu::separator {
    height: 1px;
    background-color: #F1F5F9;
    margin: 6px 16px;
}

/* ========== 状态栏 ========== */
QStatusBar {
    background-color: #F1F5F9;
    color: #64748B;
    border-top: 1px solid #E2E8F0;
    padding: 8px 16px;
    font-size: 12px;
}

/* ========== 按钮基础样式 ========== */
QPushButton {
    background-color: #3B82F6;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    min-width: 80px;
    font-weight: 500;
    font-size: 13px;
}

QPushButton:hover {
    background-color: #2563EB;
}

QPushButton:pressed {
    background-color: #1D4ED8;
}

QPushButton:disabled {
    background-color: #CBD5E1;
    color: #94A3B8;
}

/* ========== 功能按钮区分 ========== */

/* 刷新数据表按钮 - 深灰 */
QPushButton#pushButton {
    background-color: #475569;
}
QPushButton#pushButton:hover {
    background-color: #334155;
}

/* PCA/数据降维按钮 - 蓝灰 */
QPushButton#btn_pca {
    background-color: #64748B;
}
QPushButton#btn_pca:hover {
    background-color: #475569;
}

/* RF/训练模型按钮 - 绿色 */
QPushButton#btn_rf {
    background-color: #10B981;
}
QPushButton#btn_rf:hover {
    background-color: #059669;
}

/* 预测按钮 - 橙色（醒目 CTA） */
QPushButton#btn_pd {
    background-color: #F97316;
    font-size: 14px;
    font-weight: bold;
    padding: 12px 28px;
    border-radius: 10px;
}
QPushButton#btn_pd:hover {
    background-color: #EA580C;
}
QPushButton#btn_pd:pressed {
    background-color: #C2410C;
}

/* 日志按钮 - 次要样式 */
QPushButton#showlog_btn {
    background-color: transparent;
    color: #64748B;
    border: 1px solid #CBD5E1;
    padding: 8px 16px;
}
QPushButton#showlog_btn:hover {
    background-color: #F1F5F9;
    border-color: #94A3B8;
    color: #334155;
}

/* ========== 下拉框 ========== */
QComboBox {
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    padding: 9px 14px;
    background-color: #FFFFFF;
    min-height: 22px;
    color: #334155;
}

QComboBox:hover {
    border-color: #94A3B8;
}

QComboBox:focus {
    border-color: #3B82F6;
    outline: none;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 32px;
    border-left: 1px solid #E2E8F0;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    background-color: #F8FAFC;
}

QComboBox::drop-down:hover {
    background-color: #F1F5F9;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #64748B;
}

QComboBox QAbstractItemView {
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    background-color: #FFFFFF;
    selection-background-color: #EFF6FF;
    outline: none;
    padding: 6px 0px;
}

QComboBox QAbstractItemView::item {
    padding: 10px 16px;
    min-height: 22px;
    color: #334155;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #EFF6FF;
    color: #1D4ED8;
}

/* ========== 表格 ========== */
QTableWidget {
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    background-color: #FFFFFF;
    gridline-color: #F1F5F9;
    selection-background-color: #EFF6FF;
}

QTableWidget::item {
    padding: 10px 8px;
    border-bottom: 1px solid #F8FAFC;
    color: #334155;
}

QTableWidget::item:selected {
    background-color: #EFF6FF;
    color: #1D4ED8;
}

QTableWidget::item:hover {
    background-color: #F8FAFC;
}

QHeaderView::section {
    background-color: #F8FAFC;
    padding: 12px 10px;
    border: none;
    border-bottom: 2px solid #E2E8F0;
    border-right: 1px solid #F1F5F9;
    font-weight: 600;
    color: #475569;
}

QHeaderView::section:hover {
    background-color: #F1F5F9;
}

QTableWidget QTableCornerButton::section {
    background-color: #F8FAFC;
    border: none;
    border-bottom: 2px solid #E2E8F0;
    border-right: 1px solid #F1F5F9;
}

/* ========== 输入表格 ========== */
#showinput_tableWidget {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    gridline-color: #F1F5F9;
    selection-background-color: #EFF6FF;
}

#showinput_tableWidget::item {
    padding: 8px;
    border-bottom: 1px solid #F1F5F9;
    color: #1E293B;
    background-color: #FFFFFF;
}

#showinput_tableWidget::item:hover {
    background-color: #F8FAFC;
}

#showinput_tableWidget::item:selected {
    background-color: #EFF6FF;
    color: #1D4ED8;
}

#showinput_tableWidget QHeaderView::section {
    background-color: #F8FAFC;
    padding: 10px 8px;
    border: none;
    border-bottom: 2px solid #E2E8F0;
    border-right: 1px solid #F1F5F9;
    font-weight: 600;
    color: #475569;
}

/* ========== 文本编辑框 ========== */
QTextEdit {
    border: 1px solid #CBD5E1;
    border-radius: 10px;
    padding: 14px;
    background-color: #FFFFFF;
    color: #334155;
    selection-background-color: #DBEAFE;
}

QTextEdit:hover {
    border-color: #94A3B8;
}

QTextEdit:focus {
    border-color: #3B82F6;
    outline: none;
}

/* ========== 标签 ========== */
QLabel {
    color: #334155;
    background-color: transparent;
    padding: 2px 4px;
}

/* 功能性标签 */
QLabel#showtext_label,
QLabel#showtext_label_2,
QLabel#label {
    font-weight: 600;
    color: #475569;
}

/* 通知标签 */
QLabel#notification_label {
    font-weight: 700;
    color: #3B82F6;
}

/* 时间标签 */
QLabel#showtime_label {
    font-weight: 700;
    color: #F97316;
}

/* ========== 进度条 ========== */
QProgressBar {
    border: none;
    border-radius: 6px;
    background-color: #E2E8F0;
    text-align: center;
    color: #1E293B;
    font-weight: 700;
    min-height: 10px;
}

QProgressBar::chunk {
    background-color: #3B82F6;
    border-radius: 6px;
}

/* ========== 中心部件 ========== */
QWidget#centralwidget {
    background-color: transparent;
}

/* ========== 滚动条 ========== */
QScrollBar:vertical {
    background-color: #F8FAFC;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background-color: #CBD5E1;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #94A3B8;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #F8FAFC;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background-color: #CBD5E1;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #94A3B8;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}
</string>
